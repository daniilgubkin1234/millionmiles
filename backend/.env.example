APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://encar:encar@db:5432/encar
ADMIN_TOKEN=local-admin-token
SCRAPER_BASE_URL=https://car.encar.com/
SCRAPER_LIST_URL_TEMPLATE=https://car.encar.com/list/car?page={page}&search=%7B%22type%22%3A%22car%22%2C%22action%22%3A%22%28And.Hidden.N._.CarType.A.%29%22%2C%22toggle%22%3A%7B%7D%2C%22layer%22%3A%22%22%2C%22sort%22%3A%22MobileModifiedDate%22%7D
SCRAPER_MAX_CARS=36
SCRAPER_MAX_PAGES=5
SCRAPER_HEADLESS=true
SCHEDULER_RUN_ON_START=true
SCHEDULER_INTERVAL_HOURS=24
ALLOWED_ORIGINS=http://localhost:3000
